# ==============================================================================
# Configuration des Clés API - Assistant Médical Multi-Agents
# Remplissez ces clés et copiez ce fichier vers ".env" pour l'activer.
# ==============================================================================

# 1. Option OpenAI (Recommandée)
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini

# 2. Option OpenRouter (Alternative)
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# LLM_MODEL=meta-llama/llama-3-8b-instruct:free

# 3. Option Gemini (Alternative via endpoint compatible OpenAI)
# GEMINI_API_KEY=your_gemini_api_key_here
# LLM_MODEL=gemini-1.5-flash

# 4. Option Tavily Search (Recherche médicale externe via MCP)
TAVILY_API_KEY=your_tavily_api_key_here
